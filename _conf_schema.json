{
    "IP": {
        "description": "链接至GsCore的IP地址",
        "type": "string",
        "hint": "默认应为127.0.0.1或localhost",
        "default": "localhost"
    },
    "PORT": {
        "description": "链接至GsCore的端口",
        "type": "string",
        "hint": "默认应为8765",
        "default": "8765"
    },
    "BOT_ID": {
        "description": "向GsCore注册自身的Bot",
        "type": "string",
        "hint": "默认应为AstrBot",
        "default": "AstrBot"
    },
    "WS_TOKEN": {
        "description": "连接Core的WsToken",
        "type": "string",
        "hint": "WsToken",
        "default": ""
    },
    "BASE_URL": {
        "description": "GsCore资源服务器的BaseURL，用于拼接下发的相对图片/语音/视频链接",
        "type": "string",
        "hint": "例如 http://localhost:8765 。留空时默认使用 http://{IP}:{PORT}",
        "default": ""
    },
    "GSCORE_ONLY_PREFIXES": {
        "description": "仅允许转发到GsCore的普通消息前缀列表；为空时转发全部普通消息",
        "type": "list",
        "hint": "例如: core, gs, sr, zzz, ww。配置后，未命中这些前缀的普通消息不会转发到GsCore",
        "default": []
    },
    "MAX_RETRY_TIMES": {
        "description": "GsCore连接断开后的最大重试次数",
        "type": "int",
        "hint": "默认30次，-1为无限重试",
        "default": 30
    }
}
